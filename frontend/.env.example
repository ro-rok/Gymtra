# Local development — direct API (no proxy)
VITE_API_BASE_URL=http://localhost:8000

# Production (Vercel): leave VITE_API_BASE_URL empty so /api is proxied via vercel.json (persistent PWA login).
# See ../deploy/vercel.env.production

# Optional — used for canonical/OG metadata when not inferring from window.location
# VITE_PUBLIC_BASE_URL=http://localhost:8080
