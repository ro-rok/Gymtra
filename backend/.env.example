# -------------------------
# APP
# -------------------------
APP_NAME=Gymtra API
APP_ENV=development
API_PREFIX=/api/v1
PUBLIC_BASE_URL=http://localhost:8080

# -------------------------
# DATABASE
# -------------------------
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=gymtraa

# -------------------------
# AUTH - JWT
# -------------------------
JWT_SECRET_KEY=dev-secret-change-in-prod
JWT_ALGORITHM=HS256

# Short-lived access token (dev-friendly but realistic)
JWT_EXPIRE_MINUTES=30

# Refresh token (DB-backed) — 30 recommended for production persistent login
REFRESH_TOKEN_EXPIRE_DAYS=30

# -------------------------
# AUTH - COOKIES
# -------------------------
AUTH_COOKIE_NAME=gymtra_access_token
REFRESH_COOKIE_NAME=gymtra_refresh_token

AUTH_COOKIE_HTTPONLY=true
AUTH_COOKIE_SECURE=false              # false in dev, MUST be true in prod
AUTH_COOKIE_SAMESITE=none             # required for cross-origin (Vercel ↔ Render)
AUTH_COOKIE_DOMAIN=                   # empty for localhost

# -------------------------
# CORS
# -------------------------
FRONTEND_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
ALLOW_CREDENTIALS=true

# -------------------------
# TENANT SECURITY
# -------------------------
ENFORCE_TENANT_ISOLATION=true

# -------------------------
# QR ATTENDANCE
# -------------------------
QR_TOKEN_SECRET=dev-qr-secret-change-in-prod
QR_TOKEN_TTL_SECONDS=60
QR_ENFORCE_SINGLE_USE=true
QR_ENFORCE_ONE_CHECKIN_PER_DAY=true

# -------------------------
# PUSH NOTIFICATIONS (DEV SAFE)
# -------------------------
ENABLE_PUSH_NOTIFICATIONS=false

VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:admin@gymtra.local

# -------------------------
# CLOUDINARY
# -------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=gymtra

# -------------------------
# NOTIFICATION CONTROL
# -------------------------
NOTIFICATION_THROTTLE_SECONDS=300
NOTIFICATION_MAX_PER_USER_PER_DAY=5

# -------------------------
# REMINDER ENGINE
# -------------------------
ENABLE_REMINDER_ENGINE=true
REMINDER_DEDUPE_WINDOW_MINUTES=60

# -------------------------
# LOGGING
# -------------------------
LOG_LEVEL=DEBUG
ENABLE_AUDIT_LOGS=true

# -------------------------
# RATE LIMITING (OFF IN DEV)
# -------------------------
ENABLE_RATE_LIMITING=false
RATE_LIMIT_PER_MINUTE=60

# -------------------------
# RENDER KEEP-ALIVE (auto on Render via RENDER env)
# -------------------------
# Self-ping interval in seconds (default 840 = 14 minutes)
KEEPALIVE_INTERVAL=840